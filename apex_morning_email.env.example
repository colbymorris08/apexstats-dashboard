# Copy to:   ~/.apexstats_morning_email.env
# Then:      chmod 600 ~/.apexstats_morning_email.env
# Reload job: launchctl unload ~/Library/LaunchAgents/com.colbymorris.apexdashboard.morning.plist
#             launchctl load ~/Library/LaunchAgents/com.colbymorris.apexdashboard.morning.plist
#
# Microsoft 365 (Outlook / apexbaseball.com):
# If you see "SMTP AUTH is disabled for the Tenant", an admin must allow SMTP AUTH
# for this mailbox (Entra / Exchange): https://aka.ms/smtp_auth_disabled
# export APEX_SMTP_HOST="smtp.office365.com"
# export APEX_SMTP_PORT="587"
# export APEX_SMTP_USER="colbym@apexbaseball.com"
# export APEX_SMTP_PASSWORD="PASTE_PASSWORD_OR_APP_PASSWORD_HERE"
# export APEX_PDF_EMAIL_FROM="colbym@apexbaseball.com"
# export APEX_PDF_EMAIL_TO="recipient1@example.com,recipient2@example.com"
# Optional: where PDFs are written (default: apexstats folder next to JSON)
# export APEX_PDF_OUT_DIR="/Users/colbymorris/apexstats"
# Optional: schedule date for probable starters (default = day after last_night_date in JSON).
# Override only if needed:
# export APEX_PROBABLE_DATE="2026-05-12"

# --- Gmail (works when Google "App password" is enabled on the account) ---
# export APEX_SMTP_HOST="smtp.gmail.com"
# export APEX_SMTP_PORT="587"
# export APEX_SMTP_USER="you@gmail.com"
# export APEX_SMTP_PASSWORD="your-16-char-app-password"
# export APEX_PDF_EMAIL_FROM="you@gmail.com"
# export APEX_PDF_EMAIL_TO="colleague@company.com"
