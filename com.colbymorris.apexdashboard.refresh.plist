<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.colbymorris.apexdashboard.refresh</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/colbymorris/apexstats/refresh_apex_dashboard_data.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/colbymorris/apexstats</string>

  <key>StartInterval</key>
  <integer>21600</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/colbymorris/apexstats/apex_refresh.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/colbymorris/apexstats/apex_refresh.err.log</string>
</dict>
</plist>
